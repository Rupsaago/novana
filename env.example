# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to GitHub — it contains secret keys!
# This .env.example file IS safe to commit (it has no real values).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — find these at: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — find this at: platform.openai.com → API Keys
# IMPORTANT: No NEXT_PUBLIC_ prefix — this stays server-side only
OPENAI_API_KEY=

# Your app URL
# Local:    http://localhost:3000
# Deployed: https://yourapp.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
